{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "CLERK_SECRET_KEY",
    "MUX_TOKEN_ID",
    "MUX_ACCESS_TOKEN_ID",
    "MUX_SECRET_KEY",
    "LAB_SERVICE_URL",
    "LAB_SERVICE_API_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_SECRET_KEY",
    "STRIPE_PRICE_ID",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
    "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
    "NEXT_PUBLIC_SITE_URL",
    "STRIPE_ANNUAL_PRICE_ID",
    "INDEXNOW_SECRET",
    "VERCEL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_ENABLE_ASSISTANT",
    "RESEND_API_KEY",
    "COMMERCE_S3_REGION",
    "COMMERCE_S3_BUCKET",
    "COMMERCE_S3_ACCESS_KEY_ID",
    "COMMERCE_S3_SECRET_ACCESS_KEY",
    "COMMERCE_S3_ENDPOINT",
    "COMMERCE_MERCHANT_COUNTRY",
    "COMMERCE_SUPPORT_EMAIL",
    "ENABLE_STRIPE_SPT",
    "LOG_LEVEL",
    "CRON_SECRET",
    "STRIPE_TAX_CODE_DIGITAL",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    }
  }
}
