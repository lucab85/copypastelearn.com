{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://copypastelearn.com/schemas/agent-checkout-request.schema.json",
  "title": "AgentCheckoutRequest",
  "type": "object",
  "required": ["items", "payment"],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["product_id", "quantity"],
        "additionalProperties": false,
        "properties": {
          "product_id": { "type": "string", "minLength": 1 },
          "quantity":   { "type": "integer", "minimum": 1, "maximum": 100 }
        }
      }
    },
    "customer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "email": { "type": "string", "format": "email" }
      }
    },
    "payment": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["stripe_checkout", "stripe_shared_payment_token"]
        },
        "shared_payment_token": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "stripe_shared_payment_token" } } },
          "then": { "required": ["shared_payment_token"] }
        }
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
